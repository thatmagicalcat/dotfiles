# ~/.xbindkeysrc

# Decrease volume
"bash /home/thatmagicalcat/controls/voldown.sh"
   XF86AudioLowerVolume

# Increase volume
"bash /home/thatmagicalcat/controls/volup.sh"
   XF86AudioRaiseVolume

# Mute volume
"bash /home/thatmagicalcat/controls/volmute.sh"
   XF86AudioMute

#----BACKLIGHT----#

# Increase backlight
"bash /home/thatmagicalcat/controls/brtnsup.sh"
   XF86MonBrightnessUp

# Decrease backlight
"bash /home/thatmagicalcat/controls/brtnsdown.sh"
   XF86MonBrightnessDown

# Caps Lock
"xdotool key Caps_Lock && kill -45 $(pidof dwmblocks)"
  Caps_Lock

# Num lock
"xdotool key Num_Lock && kill -46 $(pidof dwmblocks)"
  Num_Lock

#----Misc----#
"alacritty -e python3"
   XF86Calculator

"emacsclient -c -a 'emacs'"
   XF86Launch1

#----Keyboard----#
"playerctl play-pause"
  XF86AudioPlay

"playerctl next"
  XF86AudioNext

"playerctl previous"
  XF86AudioPrev

"playerctl stop"
  XF86AudioStop
